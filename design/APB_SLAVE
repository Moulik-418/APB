`timescale 1ns / 1ps

module APB_SLAVE(PWRITE, PREADY, PSEL,PENABLE,paddr,pwdata, prdata, PCLK,PRESETn, PSLAVERR, transfer);
input PWRITE, transfer;
output reg PREADY, PSLAVERR;
input PSEL;
input PENABLE;
input [7:0]paddr;
input [7:0]pwdata;
output reg [7:0]prdata;
input PCLK, PRESETn;

reg [7:0]mem[7:0];
//reg [1:0]states ;

always@(posedge PCLK)begin 
if(!PRESETn)begin 
    PREADY <= 1'b0;
    PSLAVERR <= 1'b0;
    prdata <= 8'd0;      
end
else begin 
    if(PSEL && PENABLE && transfer)begin
       if(paddr > 3'd7)begin 
            PSLAVERR <= 1'b1;
            PREADY <= 1'b0;
       end     
       else begin 
            PREADY <= 1'b1;
            PSLAVERR <= 1'b0;
                if(PWRITE)begin 
                    mem[paddr] <= pwdata;
                end
                else prdata <= mem[paddr];
       end
    end
    else begin 
     PREADY <= 1'b0;
     PSLAVERR <= 1'b0;    
end
end
end
endmodule
